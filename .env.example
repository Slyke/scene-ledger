PORT=3000
DB_DRIVER=sqlite
DB_PATH=./data/cctv-scene.db
DATABASE_URL=postgres://user:pass@host:5432/cctv_scene

OLLAMA_URL=http://192.168.1.5:11434/api/chat
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_TEMPERATURE=0
OLLAMA_NUM_PREDICT=768
PREVIOUS_FRAME_MAX_AGE_SECONDS=600

IMAGE_ROOT=./images
IMAGE_STORAGE_ROOT=./data/images
THUMB_STORAGE_ROOT=./data/thumbs
MAX_IMAGE_MB=15

RETENTION_DAYS_ORIGINAL=14
RETENTION_DAYS_THUMBNAIL=90
RETENTION_DAYS_METADATA=365

API_KEY=
TRUST_PROXY=true
ANALYSE_RATE_LIMIT_PER_MINUTE=30

ERROR_FILE_PATH=./src/errors.json
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_FORMAT=text
LOG_CONSOLE_LEVELS=info,warn,error,debug
LOG_FILE_ENABLED=false
LOG_FILE_FORMAT=json
LOG_FILE_PATH=./logs/app.jsonl
LOG_FILE_LEVELS=warn,error
LOG_HTTP_ENABLED=false
LOG_HTTP_URL=
LOG_HTTP_METHOD=POST
LOG_HTTP_TIMEOUT_MS=2500
LOG_K8S_METADATA_ENABLED=false
